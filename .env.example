# Apify API Token - Get it from https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_api_token_here

# Set to 1 to bypass system proxy for Apify calls (recommended on Windows).
DISABLE_SYSTEM_PROXY=1
# Optional when not bypassing all system proxy settings:
# NO_PROXY=api.apify.com,localhost,127.0.0.1

# Job Scraping Configuration (optional - modify directly in code if needed)
# SEARCH_KEYWORD=".NET Developer"
# SEARCH_LOCATION="India"
# TOTAL_JOBS=100
