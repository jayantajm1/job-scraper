# Copy to .env.production and set real values
APIFY_API_TOKEN=replace_with_real_token
SECRET_KEY=replace_with_long_random_value
FLASK_ENV=production
ALLOWED_ORIGINS=https://your-domain.com
TZ=Asia/Kolkata
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=false
JOB_DATA_DIR=/app/data
LOG_LEVEL=INFO
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
